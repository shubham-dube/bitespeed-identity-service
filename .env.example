# ===============================
# Application
# ===============================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ===============================
# Database
# Format: postgresql://user:password@host:port/db
# ===============================
DATABASE_URL=postgresql://postgres:password@localhost:5432/my_database

# ===============================
# Security
# ===============================
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100